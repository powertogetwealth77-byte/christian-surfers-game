# Trusted worker configuration. Never expose these values to the Expo client.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

WORKER_ID=viral-clipz-worker-1
WORKER_POLL_MS=3000
WORKER_JOB_TIMEOUT_MS=1800000
TEMP_DIRECTORY=/tmp/viral-clipz
SOURCE_BUCKET=viral-clipz-sources
OUTPUT_BUCKET=viral-clipz-outputs
MAX_VIDEO_DURATION_SECONDS=10800

# Use fixture for infrastructure testing without AI spend.
# Switch to deepgram for real transcripts.
TRANSCRIPTION_PROVIDER=fixture
DEEPGRAM_API_KEY=
