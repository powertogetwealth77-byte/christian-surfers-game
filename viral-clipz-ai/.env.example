# Viral Clipz AI — client-safe configuration only.
# NEVER put a Supabase service-role key, RevenueCat secret key, or any other
# privileged credential in this file or anywhere in the client bundle.

# Supabase (public anon credentials — safe for clients, enforced by RLS)
EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=

# Analytics (PostHog public project API key)
EXPO_PUBLIC_POSTHOG_KEY=
EXPO_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# Error reporting (Sentry public DSN)
EXPO_PUBLIC_SENTRY_DSN=

# RevenueCat public SDK keys (per-platform, public by design)
EXPO_PUBLIC_REVENUECAT_IOS_KEY=
EXPO_PUBLIC_REVENUECAT_ANDROID_KEY=

# Leave Supabase vars empty to run the app in Demo Mode: the full UI works
# against clearly-labeled local sample data and no network calls are made.
